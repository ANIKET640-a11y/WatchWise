{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "watchwise.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/watchwise",
      "dest": "/watchwise.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
